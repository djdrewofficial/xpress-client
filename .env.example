# Copy to .env and fill in. Expo only exposes vars prefixed EXPO_PUBLIC_.
EXPO_PUBLIC_SUPABASE_URL=https://qjnzicqvzmvwryisjvip.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# XOS web base URL — used for music search / preview / Spotify import endpoints.
# Dev on a phone: use your computer's LAN IP (e.g. http://192.168.1.20:3000).
# Prod: https://xos.xpressdjs.com
EXPO_PUBLIC_API_URL=https://xos.xpressdjs.com
