{
  "expo": {
    "name": "Xpress Entertainment",
    "slug": "xpress-client",
    "version": "1.0.0",
    "icon": "./src/assets/icon.png",
    "orientation": "portrait",
    "scheme": "xpressclient",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xpressentertainment.client",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.xpressentertainment.client",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#4b328e",
          "imageWidth": 120
        }
      ],
      "expo-audio",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Xpress to use your photos to set your event header photo."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6adaa737-a3a0-4d16-ad16-361a15fcab94"
      }
    },
    "owner": "drewsegura"
  }
}
